# Generated by Cargo
debug/
target/

# Rustfmt backup files
**/*.rs.bk

# MSVC debug info
*.pdb

# ── Secrets & Credentials ──────────────────────────────────────────────────────
.env
.env.*
!.env.example
secrets/
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
id_rsa
id_ed25519
*.ppk
.ssh/

# Porcupine access key files
*.ppn
porcupine_params*.pv
pvporcupine_*.key

# ── Local / Machine-Specific Config ───────────────────────────────────────────
*.local.toml
*.local.yaml
*.local.json
config.local.*
config/local/
tailscale.conf
network.conf

# ── AI / ML Model Weights ─────────────────────────────────────────────────────
# (large binary blobs — track versions in docs, not git)
*.gguf
*.ggml
ggml-*.bin
whisper-*.bin
*.pt
*.onnx
models/*
# Wake word assets are small and version-controlled (samples + .rpw trained model)
!models/wake-word/
!models/wake-word/**

# ── Logs & Runtime State ──────────────────────────────────────────────────────
*.log
logs/
*.pid

# ── OS & Editor Artifacts ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
*.swp
*~

# ── Build / Deploy Artifacts ──────────────────────────────────────────────────
dist/
out/

# ── Python (utility scripts) ──────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/

# ── Private project files ─────────────────────────────────────────────────────
/private
/.claude
